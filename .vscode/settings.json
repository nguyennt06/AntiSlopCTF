{
  // =========================================================
  // Cấu hình paste ảnh cho Markdown
  // Yêu cầu extension: "mushan.vscode-paste-image"
  // Ảnh paste sẽ lưu vào: images/image1.png, image2.png, ...
  // =========================================================

  // --- Extension: Paste Image (mushan.vscode-paste-image) ---
  // Thư mục lưu ảnh (tương đối so với file đang mở)
  "pasteImage.path": "${projectRoot}/images",

  // Tiền tố tên file
  "pasteImage.namePrefix": "image",

  // Hậu tố: để trống (không dùng timestamp)
  "pasteImage.nameSuffix": "",

  // Dùng timestamp làm tên? -> false để đánh số thứ tự thủ công
  // (Paste Image sẽ hỏi tên, ta có thể tự gõ số hoặc để nguyên prefix)
  "pasteImage.showFilePathConfirmInputBox": false,

  // Không encode đường dẫn
  "pasteImage.encodePath": "none",

  // Chèn vào Markdown dạng tương đối
  "pasteImage.insertPattern": "![${imageFileNameWithoutExt}](images/${imageFileName})",

  // --- VS Code built-in (v1.79+): dự phòng nếu không dùng extension ---
  // Ảnh paste sẽ vào thư mục images/ cùng tên file markdown
  "markdown.copyFiles.destination": {
    "**/*.md": "images/"
  }
}
